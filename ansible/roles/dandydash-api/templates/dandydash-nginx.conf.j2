# Generada per Ansible - {{ domain }}
# Protecció contra DoS: límit de peticions per IP
limit_req_zone $binary_remote_addr zone=dandydash_limit:10m rate=20r/s;

# Redirecció HTTP → HTTPS
server {
    listen 80;
    server_name {{ app_ip }} {{ domain }};
    return 301 https://$host$request_uri;
}

# Bloc HTTPS principal
server {
    listen 443 ssl;
    server_name {{ app_ip }} {{ domain }};

    # Certificats SSL
    ssl_certificate     {{ ssl_dir }}/cert.pem;
    ssl_certificate_key {{ ssl_dir }}/key.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Logs
    access_log /var/log/nginx/dandydash_access.log;
    error_log  /var/log/nginx/dandydash_error.log warn;

    # Límit de peticions
    limit_req zone=dandydash_limit burst=20 nodelay;

    # Pàgines d'error personalitzades
    error_page 400 401 402 403 404 /error/400.html;
    error_page 500 501 502 503 504 /error/500.html;

    # Frontend estàtic
    location / {
        root {{ frontend_dir }};
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    # API Backend → Gunicorn
    location /api/ {
        proxy_pass         http://127.0.0.1:5000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 90;
    }
}
