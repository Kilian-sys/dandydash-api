#!/bin/bash
# Script per generar certificats SSL autofirmats
mkdir -p {{ ssl_dir }}

if [ ! -f {{ ssl_dir }}/cert.pem ]; then
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
        -keyout {{ ssl_dir }}/key.pem \
        -out {{ ssl_dir }}/cert.pem \
        -subj "/C=ES/ST=Catalunya/L=Barcelona/O=DandyDash/CN={{ domain }}"

    chmod 600 {{ ssl_dir }}/key.pem
    chmod 644 {{ ssl_dir }}/cert.pem
    echo "Certificats SSL generats correctament"
else
    echo "Els certificats SSL ja existeixen"
fi
